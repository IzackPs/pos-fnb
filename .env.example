# Environment
# Copy this file to .env and fill in your values.
# ⚠️ NEVER commit .env to git.

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-string"

# Your app URL (used by NextAuth for callbacks)
AUTH_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Desenvolvimento local (sem Docker)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/posfnb?schema=public"

# Docker Compose (o DATABASE_URL é montado automaticamente pelo compose)
# Defina apenas as variáveis individuais abaixo e o compose monta a URL

POSTGRES_DB=posfnb
POSTGRES_USER=posfnb
POSTGRES_PASSWORD=changeme

# Produção (Railway, Supabase, Neon, etc.) — cole a URL completa aqui
DATABASE_URL="postgresql://posfnb:changeme@localhost:5432/posfnb?schema=public"

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token do túnel gerado no painel Zero Trust da Cloudflare
CLOUDFLARE_TUNNEL_TOKEN="seu-token-aqui"
